<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="carcare"/>
  <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>
  <property name="LOG_PATTERN" value="time=%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%level app=${APP_NAME} correlationId=%X{correlationId:-none} thread=%thread logger=%logger{36} message=&quot;%msg&quot;%n%ex"/>
  <property name="COLOR_LOG_PATTERN" value="%clr(time=){faint}%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint} %clr(level=){faint}%clr(%-5level) %clr(app=){faint}%clr(${APP_NAME}){cyan} %clr(correlationId=){faint}%clr(%X{correlationId:-none}){magenta} %clr(thread=){faint}%clr(%thread){faint} %clr(logger=){faint}%clr(%logger{36}){blue} %clr(message=){faint}%msg%n%clr(%ex){red}"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <springProfile name="local">
    <appender name="CONSOLE_COLOR" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>${COLOR_LOG_PATTERN}</pattern>
      </encoder>
    </appender>
  </springProfile>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/${APP_NAME}.log</file>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>30</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <logger name="org.hibernate.SQL" level="WARN"/>
  <logger name="org.hibernate.orm.jdbc.bind" level="WARN"/>

  <springProfile name="local">
    <root level="INFO">
      <appender-ref ref="CONSOLE_COLOR"/>
      <appender-ref ref="FILE"/>
    </root>
  </springProfile>

  <springProfile name="!local">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE"/>
    </root>
  </springProfile>
</configuration>
